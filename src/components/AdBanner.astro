---
interface Props {
  slot?: "leaderboard" | "sidebar" | "inline";
  class?: string;
}

const { slot = "inline", class: className = "" } = Astro.props;

const sizeClasses: Record<string, string> = {
  leaderboard: "w-full max-w-[728px] h-[90px]",
  sidebar: "w-[300px] h-[250px]",
  inline: "w-full max-w-[468px] h-[60px]",
};
---

<div class:list={["ad-container mx-auto my-6 flex items-center justify-center", className]}>
  <div class:list={[
    "bg-slate-100 border border-dashed border-slate-300 rounded-lg flex items-center justify-center text-slate-400 text-xs",
    sizeClasses[slot]
  ]}>
    <!--
      Replace this div with actual ad code, e.g.:
      <ins class="adsbygoogle"
        style="display:block"
        data-ad-client="ca-pub-XXXXXXX"
        data-ad-slot="XXXXXXX"
        data-ad-format="auto"
        data-full-width-responsive="true">
      </ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    -->
    <span>Espace publicitaire</span>
  </div>
</div>
