---
interface Props {
  slot?: "leaderboard" | "sidebar" | "inline";
  class?: string;
}

const { slot = "inline", class: className = "" } = Astro.props;
---

<div class:list={["ad-container mx-auto my-6", className]}>
  <ins class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-3196841364433142"
    data-ad-format="auto"
    data-full-width-responsive="true">
  </ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>
