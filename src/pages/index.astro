---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdBanner from '../components/AdBanner.astro';
import { axes } from '../data/questions';
import { politicians } from '../data/politicians';
---

<Layout title="Boussole2027 — Quel candidat vous ressemble le plus ?">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary via-primary-light to-indigo-400 text-white">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-10 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 right-10 w-96 h-96 bg-amber-300 rounded-full blur-3xl"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-4 py-20 md:py-32 text-center">
        <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm rounded-full px-4 py-1.5 text-sm font-medium text-indigo-100 mb-8">
          Présidentielle 2027
        </div>
        <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6">
          Quel candidat<br/>
          <span class="text-amber-300">vous ressemble</span> le plus ?
        </h1>
        <p class="text-lg md:text-xl text-indigo-100 max-w-2xl mx-auto mb-10 leading-relaxed">
          45 questions, 6 axes d'analyse, 11 personnalités politiques. Découvrez avec qui vous êtes le plus compatible pour 2027.
        </p>
        <a
          href="/quiz"
          class="inline-flex items-center gap-2 bg-white text-primary font-bold text-lg px-8 py-4 rounded-full shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300"
        >
          Trouver mon candidat
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <p class="mt-6 text-indigo-200 text-sm">Environ 7 minutes — Gratuit — Anonyme — Sans inscription</p>
      </div>
    </section>

    <AdBanner slot="leaderboard" class="mt-8" />

    <!-- Politicians preview -->
    <section class="max-w-5xl mx-auto px-4 py-16 md:py-24">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">11 candidats comparés</h2>
      <p class="text-muted text-center max-w-xl mx-auto mb-12">
        De Mélenchon à Zemmour, découvrez avec qui vos idées sont les plus alignées.
      </p>
      <div class="flex flex-wrap justify-center gap-3 md:gap-4">
        {politicians.map((p) => (
          <div class="flex items-center gap-2 bg-white rounded-full px-4 py-2.5 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="w-3 h-3 rounded-full shrink-0" style={`background-color: ${p.color}`}></div>
            <span class="font-medium text-sm">{p.name}</span>
            <span class="text-xs text-muted">{p.partyShort}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Axes Preview -->
    <section class="bg-white py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">6 axes analysés</h2>
        <p class="text-muted text-center max-w-xl mx-auto mb-12">
          La politique ne se résume pas à gauche ou droite. Explorez chaque dimension de vos convictions.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {axes.map((axis) => (
            <div class="group bg-surface rounded-2xl p-6 border border-slate-100 hover:shadow-lg hover:border-slate-200 transition-all duration-300">
              <div class="text-3xl mb-3">{axis.emoji}</div>
              <h3 class="font-bold text-lg mb-2" style={`color: ${axis.color}`}>{axis.label}</h3>
              <p class="text-sm text-muted">
                <span class="font-medium text-slate-700">{axis.poleLeft}</span>
                {" "}vs{" "}
                <span class="font-medium text-slate-700">{axis.poleRight}</span>
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <AdBanner slot="inline" />

    <!-- How It Works -->
    <section class="max-w-5xl mx-auto px-4 py-16 md:py-24">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Comment ça marche ?</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
          <h3 class="font-semibold text-lg mb-2">Répondez aux questions</h3>
          <p class="text-muted text-sm">45 affirmations sur des sujets politiques concrets. Indiquez votre degré d'accord sur une échelle de 1 à 5.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
          <h3 class="font-semibold text-lg mb-2">Découvrez votre candidat</h3>
          <p class="text-muted text-sm">Vos réponses sont comparées aux positions de 11 personnalités politiques pour trouver votre meilleur match.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
          <h3 class="font-semibold text-lg mb-2">Comparez et partagez</h3>
          <p class="text-muted text-sm">Partagez votre résultat sur les réseaux sociaux et comparez-vous avec vos proches.</p>
        </div>
      </div>
    </section>

    <AdBanner slot="leaderboard" />

    <!-- CTA -->
    <section class="max-w-5xl mx-auto px-4 py-16 text-center">
      <div class="bg-gradient-to-r from-primary to-primary-light rounded-3xl p-10 md:p-16 text-white">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Prêt à trouver votre candidat ?</h2>
        <p class="text-indigo-100 mb-8 max-w-lg mx-auto">
          Le test est entièrement gratuit et anonyme. Vos réponses ne quittent jamais votre navigateur.
        </p>
        <a
          href="/quiz"
          class="inline-flex items-center gap-2 bg-white text-primary font-bold text-lg px-8 py-4 rounded-full shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300"
        >
          Lancer le quiz
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
